{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "bitforge",
  "type": "registry:style",
  "title": "Bitforge",
  "description": "Bitforge design system as a shadcn preset — neobrutalist, 8-bit terminal vibes. Hard edges, brand orange (#FF6B1A), warm dark surface + warm cream paper, terminal palette, IBM Plex Sans + JetBrains Mono + Departure Mono, brutal offset shadows.",
  "cssVars": {
    "theme": {
      "color-background": "var(--background)",
      "color-foreground": "var(--foreground)",
      "color-card": "var(--card)",
      "color-card-foreground": "var(--card-foreground)",
      "color-popover": "var(--popover)",
      "color-popover-foreground": "var(--popover-foreground)",
      "color-primary": "var(--primary)",
      "color-primary-foreground": "var(--primary-foreground)",
      "color-secondary": "var(--secondary)",
      "color-secondary-foreground": "var(--secondary-foreground)",
      "color-muted": "var(--muted)",
      "color-muted-foreground": "var(--muted-foreground)",
      "color-accent": "var(--accent)",
      "color-accent-foreground": "var(--accent-foreground)",
      "color-destructive": "var(--destructive)",
      "color-destructive-foreground": "var(--destructive-foreground)",
      "color-border": "var(--border)",
      "color-input": "var(--input)",
      "color-ring": "var(--ring)",
      "color-chart-1": "var(--chart-1)",
      "color-chart-2": "var(--chart-2)",
      "color-chart-3": "var(--chart-3)",
      "color-chart-4": "var(--chart-4)",
      "color-chart-5": "var(--chart-5)",
      "color-bf-orange": "#FF6B1A",
      "color-bf-orange-hot": "#FF8533",
      "color-bf-orange-deep": "#D9520A",
      "color-bf-orange-dim": "#7A3410",
      "color-term-green": "#2EE6A8",
      "color-term-green-dim": "#1A8C66",
      "color-term-amber": "#F2B33D",
      "color-term-red": "#FF5A5A",
      "color-term-blue": "#5AB0FF",
      "color-term-purple": "#C78BFF",
      "color-term-cyan": "#4FD8E0",
      "color-tl-red": "#FF5F57",
      "color-tl-amber": "#FEBC2E",
      "color-tl-green": "#28C840",
      "font-sans": "'IBM Plex Sans', 'Inter', system-ui, -apple-system, sans-serif",
      "font-mono": "'JetBrains Mono', 'SF Mono', 'Menlo', 'Consolas', monospace",
      "font-pixel": "'Departure Mono', 'JetBrains Mono', monospace",
      "radius-sm": "calc(var(--radius) - 4px)",
      "radius-md": "calc(var(--radius) - 2px)",
      "radius-lg": "var(--radius)",
      "radius-xl": "calc(var(--radius) + 4px)",
      "radius-bf-input": "2px",
      "radius-bf-chip": "4px",
      "radius-bf-card": "6px",
      "radius-pill": "9999px",
      "shadow-brutal-sm": "4px 4px 0 0 #0A0908",
      "shadow-brutal": "6px 6px 0 0 #0A0908",
      "shadow-brutal-lg": "10px 10px 0 0 #0A0908",
      "shadow-brutal-orange": "6px 6px 0 0 #FF6B1A",
      "shadow-glow-orange": "0 0 24px rgba(255,107,26,0.35)",
      "shadow-glow-green": "0 0 16px rgba(46,230,168,0.4)",
      "shadow-glow-soft": "0 8px 32px rgba(0,0,0,0.5)",
      "ease-out-snappy": "cubic-bezier(0.2, 0.7, 0.3, 1)",
      "ease-in-snappy": "cubic-bezier(0.7, 0, 0.8, 0.3)",
      "ease-step": "steps(4, end)"
    },
    "light": {
      "background": "#F2EEE4",
      "foreground": "#0A0908",
      "card": "#EAE5D8",
      "card-foreground": "#0A0908",
      "popover": "#EAE5D8",
      "popover-foreground": "#0A0908",
      "primary": "#FF6B1A",
      "primary-foreground": "#FFFFFF",
      "secondary": "#DCD6C5",
      "secondary-foreground": "#0A0908",
      "muted": "#DCD6C5",
      "muted-foreground": "#6E6A63",
      "accent": "#7A3410",
      "accent-foreground": "#F2EEE4",
      "destructive": "#FF5A5A",
      "destructive-foreground": "#0A0908",
      "border": "#2D2A26",
      "input": "#DCD6C5",
      "ring": "#FF6B1A",
      "chart-1": "#2EE6A8",
      "chart-2": "#F2B33D",
      "chart-3": "#5AB0FF",
      "chart-4": "#C78BFF",
      "chart-5": "#4FD8E0",
      "radius": "0rem"
    },
    "dark": {
      "background": "#0A0908",
      "foreground": "#F5F1EA",
      "card": "#121110",
      "card-foreground": "#F5F1EA",
      "popover": "#1A1816",
      "popover-foreground": "#F5F1EA",
      "primary": "#FF6B1A",
      "primary-foreground": "#FFFFFF",
      "secondary": "#232120",
      "secondary-foreground": "#F5F1EA",
      "muted": "#232120",
      "muted-foreground": "#6E6A63",
      "accent": "#232120",
      "accent-foreground": "#FF8533",
      "destructive": "#FF5A5A",
      "destructive-foreground": "#F5F1EA",
      "border": "#2A2825",
      "input": "#232120",
      "ring": "#FF6B1A",
      "chart-1": "#2EE6A8",
      "chart-2": "#F2B33D",
      "chart-3": "#5AB0FF",
      "chart-4": "#C78BFF",
      "chart-5": "#4FD8E0",
      "radius": "0rem"
    }
  },
  "css": {
    ".dark [data-slot=\"button\"]": {
      "position": "relative",
      "--btn-brutal-offset": "4px"
    },
    ".dark [data-slot=\"button\"].bg-primary": {
      "--btn-brutal-color": "var(--color-bf-orange-deep)"
    },
    ".dark [data-slot=\"button\"].bg-secondary": {
      "--btn-brutal-color": "rgba(245, 241, 234, 0.85)"
    },
    ".dark [data-slot=\"button\"][class*=\"bg-destructive\"]": {
      "--btn-brutal-color": "#8C2520"
    },
    ".dark [data-slot=\"button\"]:is(.bg-primary, .bg-secondary, [class*=\"bg-destructive\"])::after": {
      "content": "\"\"",
      "position": "absolute",
      "inset": "-1px",
      "box-sizing": "border-box",
      "border": "1px solid transparent",
      "border-right-color": "var(--btn-brutal-color)",
      "border-bottom-color": "var(--btn-brutal-color)",
      "border-radius": "inherit",
      "transform": "translate(var(--btn-brutal-offset), var(--btn-brutal-offset))",
      "pointer-events": "none",
      "transition": "transform 80ms cubic-bezier(0.2, 0.7, 0.3, 1), opacity 80ms cubic-bezier(0.2, 0.7, 0.3, 1)"
    },
    ".dark [data-slot=\"button\"]:is(.bg-primary, .bg-secondary, [class*=\"bg-destructive\"]):hover::after": {
      "transform": "translate(calc(var(--btn-brutal-offset) + 1px), calc(var(--btn-brutal-offset) + 1px))"
    },
    ".dark [data-slot=\"button\"]:is(.bg-primary, .bg-secondary, [class*=\"bg-destructive\"]):active::after": {
      "opacity": "0"
    }
  }
}
